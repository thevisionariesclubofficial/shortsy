# ── AWS region & stage ────────────────────────────────────────────────────────
# These are set automatically by Serverless Framework during deploy.
# Only override them if running scripts locally.
REGION=ap-south-1
STAGE=dev

# ── Cognito (auto-populated after first deploy via CloudFormation Outputs) ────
# After running `serverless deploy`, get these from the stack Outputs tab
# or run: aws cloudformation describe-stacks --stack-name shortsy-dev
USER_POOL_ID=ap-south-1_XXXXXXXXX
USER_POOL_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXX

# ── DynamoDB table names (match serverless.yml naming convention) ─────────────
CONTENT_TABLE=shortsy-content-dev
RENTALS_TABLE=shortsy-rentals-dev
PROGRESS_TABLE=shortsy-progress-dev
ORDERS_TABLE=shortsy-orders-dev

# ── S3 media bucket (optional — for presigned streaming URLs) ─────────────────
# If empty, stored Firebase/CDN URLs are returned as-is (good for dev)
S3_MEDIA_BUCKET=shortsy-media-dev

# ── CDN base URL (used as fallback when S3 is not configured) ────────────────
CDN_BASE=https://cdn.shortsy.app

# ── Razorpay (optional — dev mode generates mock orders when empty) ───────────
RAZORPAY_KEY_ID=rzp_test_SLajOeA4k89FaD
RAZORPAY_KEY_SECRET=KFg2xasu5pQ8P8qWphrruzAb

# ── Stream URL expiry (seconds) ───────────────────────────────────────────────
STREAM_EXPIRY_SECONDS=3600
