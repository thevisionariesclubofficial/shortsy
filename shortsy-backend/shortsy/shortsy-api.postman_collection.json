            "body": {
              "mode": "raw",
              "raw": "{\n  \"displayName\": \"Adarsh C.\",\n  \"avatarUrl\": \"https://cdn.shortsy.app/avatars/new.jpg\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "PATCH /v1/users/me\n\nUpdates displayName and/or avatarUrl via AdminUpdateUserAttributes. At least one field is required."
          },
          "event": [
