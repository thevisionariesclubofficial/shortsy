{
  "info": {
    "name": "Shortsy API",
    "_postman_id": "shortsy-api-v1",
    "description": "Complete API collection for Shortsy — all 21 endpoints across Auth, Content, Rentals, Playback, and Users.\n\n**Setup:**\n1. Set `baseUrl` to your deployed API Gateway URL (e.g. `https://xxxxxx.execute-api.ap-south-1.amazonaws.com`).\n2. Call **Auth / Sign Up** or **Auth / Log In** — the test script automatically stores `accessToken` and `refreshToken` in collection variables.\n3. All protected endpoints will then pick up the token automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "https://2tngsao13b.execute-api.ap-south-1.amazonaws.com", "type": "string" },
    { "key": "accessToken",  "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "contentId",    "value": "1", "type": "string" },
    { "key": "episodeId",    "value": "2-1", "type": "string" },
    { "key": "orderId",      "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "description": "Public endpoints — no Bearer token required (except Logout).",
      "item": [
        {
          "name": "Sign Up",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/v1/auth/signup", "host": ["{{baseUrl}}"], "path": ["v1","auth","signup"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"SecurePass123!\",\n  \"displayName\": \"Adarsh Chaudhary\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "POST /v1/auth/signup\n\nCreates a new account, auto-confirms it via AdminConfirmSignUp, and immediately returns tokens."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken',  json.tokens.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.tokens.refreshToken);",
                  "  pm.test('Signup successful', () => pm.response.to.have.status(201));",
                  "  pm.test('Has access token', () => pm.expect(json.tokens.accessToken).to.be.a('string').and.not.empty);",
                  "} else {",
                  "  pm.test('Request failed', () => pm.response.to.have.status(201));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Log In",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["v1","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"SecurePass123!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "POST /v1/auth/login\n\nExchanges email + password for JWT tokens. Tokens are auto-stored in collection variables."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken',  json.tokens.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.tokens.refreshToken);",
                  "  pm.test('Login successful', () => pm.response.to.have.status(200));",
                  "  pm.test('Has tokens', () => {",
                  "    pm.expect(json.tokens.accessToken).to.be.a('string').and.not.empty;",
                  "    pm.expect(json.tokens.refreshToken).to.be.a('string').and.not.empty;",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Forgot Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/v1/auth/forgot-password", "host": ["{{baseUrl}}"], "path": ["v1","auth","forgot-password"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "POST /v1/auth/forgot-password\n\nTriggers Cognito forgot-password flow. Always returns 200 to prevent email enumeration."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Always 200 (anti-enumeration)', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/v1/auth/refresh", "host": ["{{baseUrl}}"], "path": ["v1","auth","refresh"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "POST /v1/auth/refresh\n\nExchanges a valid refresh token for a new access token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', json.tokens.accessToken);",
                  "  pm.test('Token refreshed', () => pm.response.to.have.status(200));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Log Out",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/v1/auth/logout", "host": ["{{baseUrl}}"], "path": ["v1","auth","logout"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "POST /v1/auth/logout\n\nCalls Cognito GlobalSignOut (invalidates all tokens for this user). Requires Bearer access token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Logout returns 204', () => pm.response.to.have.status(204));",
                  "pm.collectionVariables.set('accessToken', '');",
                  "pm.collectionVariables.set('refreshToken', '');"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Content",
      "description": "Protected content endpoints — Bearer token required.",
      "item": [
        {
          "name": "List Content (Home Feed)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/content?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["v1","content"],
              "query": [
                { "key": "type",           "value": "short-film",      "disabled": true,  "description": "short-film | vertical-series" },
                { "key": "genre",          "value": "Drama",           "disabled": true },
                { "key": "language",       "value": "Hindi",           "disabled": true },
                { "key": "mood",           "value": "Emotional",       "disabled": true },
                { "key": "featured",       "value": "true",            "disabled": true },
                { "key": "festivalWinner", "value": "true",            "disabled": true },
                { "key": "page",           "value": "1",               "disabled": false },
                { "key": "limit",          "value": "20",              "disabled": false }
              ]
            },
            "description": "GET /v1/content\n\nReturns paginated content list. Toggle query params to filter by type, genre, language, mood, featured, or festivalWinner."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has data array', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.data).to.be.an('array');",
                  "  pm.expect(json.pagination).to.have.property('total');",
                  "  if (json.data.length > 0) {",
                  "    pm.collectionVariables.set('contentId', json.data[0].id);",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Featured Content",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/v1/content/featured", "host": ["{{baseUrl}}"], "path": ["v1","content","featured"] },
            "description": "GET /v1/content/featured\n\nReturns the hero item and featured content array (uses featured-index GSI)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has hero and featured', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('hero');",
                  "  pm.expect(json.featured).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Discovery Metadata",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/v1/content/metadata", "host": ["{{baseUrl}}"], "path": ["v1","content","metadata"] },
            "description": "GET /v1/content/metadata\n\nReturns static moods, genres, and languages arrays."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has moods, genres, languages', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.moods).to.be.an('array').with.length(7);",
                  "  pm.expect(json.genres).to.be.an('array');",
                  "  pm.expect(json.languages).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Search Content",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/content/search?q=midnight",
              "host": ["{{baseUrl}}"],
              "path": ["v1","content","search"],
              "query": [
                { "key": "q",     "value": "midnight", "description": "Required — searches title, director, genre" },
                { "key": "type",  "value": "vertical-series", "disabled": true },
                { "key": "limit", "value": "20",              "disabled": true }
              ]
            },
            "description": "GET /v1/content/search?q=...\n\nFull-text search across title, director, and genre."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has query and data', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('query');",
                  "  pm.expect(json.data).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Content by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/v1/content/{{contentId}}", "host": ["{{baseUrl}}"], "path": ["v1","content","{{contentId}}"] },
            "description": "GET /v1/content/:id\n\nReturns full content detail including episodeList (for vertical-series).\n\nChange `contentId` collection variable to switch between items."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has id and title', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.id).to.be.a('string');",
                  "  pm.expect(json.title).to.be.a('string');",
                  "  if (json.type === 'vertical-series' && json.episodeList && json.episodeList.length > 0) {",
                  "    pm.collectionVariables.set('episodeId', json.episodeList[0].id);",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Rentals",
      "description": "Rental & payment endpoints — Bearer token required.",
      "item": [
        {
          "name": "Initiate Rental",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/v1/rentals/initiate", "host": ["{{baseUrl}}"], "path": ["v1","rentals","initiate"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contentId\": \"{{contentId}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "POST /v1/rentals/initiate\n\nCreates a Razorpay order (or a mock order in dev mode when keys are absent). Returns gatewayOrderId + gatewayKey for the client SDK."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('orderId', json.orderId);",
                  "  pm.test('Has orderId and gatewayOrderId', () => {",
                  "    pm.expect(json.orderId).to.be.a('string');",
                  "    pm.expect(json.gatewayOrderId).to.be.a('string');",
                  "  });",
                  "} else {",
                  "  pm.test(`Response: ${pm.response.code}`, () => {});",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Confirm Payment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/v1/rentals/confirm", "host": ["{{baseUrl}}"], "path": ["v1","rentals","confirm"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"{{orderId}}\",\n  \"gatewayPaymentId\": \"rzp_pay_DEV123456\",\n  \"gatewaySignature\": \"dev_signature\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "POST /v1/rentals/confirm\n\nVerifies the Razorpay HMAC signature and writes the rental record to DynamoDB.\n\nIn dev mode (no Razorpay secret) any signature is accepted."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has rental record', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.rental).to.have.property('contentId');",
                  "  pm.expect(json.rental).to.have.property('expiresAt');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "List My Rentals",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/rentals?active=true",
              "host": ["{{baseUrl}}"],
              "path": ["v1","rentals"],
              "query": [
                { "key": "active", "value": "true", "description": "true → only non-expired rentals" }
              ]
            },
            "description": "GET /v1/rentals\n\nReturns all rentals for the authenticated user, enriched with lightweight content metadata."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has rentals array', () => {",
                  "  pm.expect(pm.response.json().rentals).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Rental Status",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/v1/rentals/{{contentId}}", "host": ["{{baseUrl}}"], "path": ["v1","rentals","{{contentId}}"] },
            "description": "GET /v1/rentals/:contentId\n\nReturns { isRented, rental } for the given content. rental is null when not rented / expired."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has isRented boolean', () => {",
                  "  pm.expect(pm.response.json()).to.have.property('isRented');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Playback",
      "description": "Streaming URLs and watch-progress endpoints — Bearer token + active rental required for stream endpoints.",
      "item": [
        {
          "name": "Get Stream URL — Short Film",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/v1/content/{{contentId}}/stream", "host": ["{{baseUrl}}"], "path": ["v1","content","{{contentId}}","stream"] },
            "description": "GET /v1/content/:id/stream\n\nReturns a signed streaming URL for a short-film. Requires an active rental.\n\nSet contentId to a short-film ID (e.g. 1, 3, 5, 6, 8)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has streamUrl', () => {",
                  "  pm.expect(pm.response.json().streamUrl).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Stream URL — Episode",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/v1/content/{{contentId}}/episodes/{{episodeId}}/stream", "host": ["{{baseUrl}}"], "path": ["v1","content","{{contentId}}","episodes","{{episodeId}}","stream"] },
            "description": "GET /v1/content/:id/episodes/:episodeId/stream\n\nReturns a signed streaming URL for a vertical-series episode. Requires an active rental.\n\nSet contentId = 2 and episodeId = 2-1 (for example)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has streamUrl and nextEpisode', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.streamUrl).to.be.a('string').and.not.empty;",
                  "  pm.expect(json).to.have.property('nextEpisode');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Save Watch Progress — Short Film",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/v1/content/{{contentId}}/progress", "host": ["{{baseUrl}}"], "path": ["v1","content","{{contentId}}","progress"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentTime\": 645,\n  \"duration\": 1080,\n  \"completed\": false\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "POST /v1/content/:id/progress — Short Film\n\nSaves playback position. Returns progressPercent."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Saved with progressPercent', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.saved).to.be.true;",
                  "  pm.expect(json.progressPercent).to.be.a('number');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Save Watch Progress — Episode",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/v1/content/{{contentId}}/progress", "host": ["{{baseUrl}}"], "path": ["v1","content","{{contentId}}","progress"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"episodeId\": \"{{episodeId}}\",\n  \"episodeNumber\": 1,\n  \"currentTime\": 87,\n  \"duration\": 132,\n  \"completed\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "POST /v1/content/:id/progress — Vertical Series Episode\n\nSaves progress for a specific episode. Appends episodeId to completedEpisodes when completed=true."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Saved with progressPercent', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.saved).to.be.true;",
                  "  pm.expect(json.progressPercent).to.be.a('number');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Watch Progress",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/v1/content/{{contentId}}/progress", "host": ["{{baseUrl}}"], "path": ["v1","content","{{contentId}}","progress"] },
            "description": "GET /v1/content/:id/progress\n\nReturns current watch progress for the authenticated user. Returns zeroed object when no progress exists yet."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has progressPercent and currentTime', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('currentTime');",
                  "  pm.expect(json).to.have.property('progressPercent');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Users",
      "description": "User profile endpoints — Bearer token required.",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/v1/users/me", "host": ["{{baseUrl}}"], "path": ["v1","users","me"] },
            "description": "GET /v1/users/me\n\nReturns authenticated user profile with aggregated stats (totalRentals, totalWatchTimeMinutes, favouriteGenre)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has id, email, stats', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.id).to.be.a('string');",
                  "  pm.expect(json.email).to.be.a('string');",
                  "  pm.expect(json.stats).to.have.property('totalRentals');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Update My Profile",
          "request": {
