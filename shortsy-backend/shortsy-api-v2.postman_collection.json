{
  "info": {
    "name": "Shortsy API v2",
    "_postman_id": "shortsy-api-v2",
    "description": "Complete API collection for Shortsy v2 — all endpoints across Auth, Order, Content, Rentals, Playback, and Users.",
    "schema": "https://schema.getpostman.com/json/collection/v1.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "https://2tngsao13b.execute-api.ap-south-1.amazonaws.com", "type": "string" },
    { "key": "accessToken",  "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "contentId",    "value": "1", "type": "string" },
    { "key": "episodeId",    "value": "2-1", "type": "string" },
    { "key": "orderId",      "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "description": "Public endpoints — no Bearer token required (except Logout).",
      "item": [
        {
          "name": "Sign Up",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/v1/auth/signup", "host": ["{{baseUrl}}"], "path": ["v2","auth","signup"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"SecurePass123!\",\n  \"displayName\": \"Adarsh Chaudhary\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "POST /v1/auth/signup\n\nCreates a new account and returns tokens."
          }
        },
        {
          "name": "Log In",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["v2","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"SecurePass123!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "POST /v1/auth/login\n\nExchanges email + password for JWT tokens."
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/v1/auth/forgot-password", "host": ["{{baseUrl}}"], "path": ["v2","auth","forgot-password"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "POST /v1/auth/forgot-password\n\nTriggers forgot-password flow."
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/v1/auth/refresh", "host": ["{{baseUrl}}"], "path": ["v2","auth","refresh"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "POST /v1/auth/refresh\n\nExchanges a valid refresh token for a new access token."
          }
        },
        {
          "name": "Log Out",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/v1/auth/logout", "host": ["{{baseUrl}}"], "path": ["v2","auth","logout"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "POST /v1/auth/logout\n\nLogs out the user and invalidates tokens."
          }
        }
      ]
    },
    {
      "name": "Order",
      "description": "Razorpay order creation endpoint — Bearer token required.",
      "item": [
        {
          "name": "Create Razorpay Order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/v1/order", "host": ["{{baseUrl}}"], "path": ["v2","order"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 100,\n  \"currency\": \"INR\",\n  \"receipt\": \"receipt#1\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "POST /v1/order\n\nCreates a Razorpay order and returns orderId, amount, currency, and receipt. Requires Bearer token."
          }
        }
      ]
    },
    {
      "name": "Content",
      "description": "Protected content endpoints — Bearer token required.",
      "item": [
        {
          "name": "List Content (Home Feed)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/content?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["v2","content"],
              "query": [
                { "key": "type",           "value": "short-film",      "disabled": true,  "description": "short-film | vertical-series" },
                { "key": "genre",          "value": "Drama",           "disabled": true },
                { "key": "language",       "value": "Hindi",           "disabled": true },
                { "key": "mood",           "value": "Emotional",       "disabled": true },
                { "key": "featured",       "value": "true",            "disabled": true },
                { "key": "festivalWinner", "value": "true",            "disabled": true },
                { "key": "page",           "value": "1",               "disabled": false },
                { "key": "limit",          "value": "20",              "disabled": false }
              ]
            },
            "description": "GET /v1/content\n\nReturns paginated content list."
          }
        },
        {
          "name": "Get Featured Content",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/v1/content/featured", "host": ["{{baseUrl}}"], "path": ["v2","content","featured"] },
            "description": "GET /v1/content/featured\n\nReturns the hero item and featured content array."
          }
        },
        {
          "name": "Get Discovery Metadata",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/v1/content/metadata", "host": ["{{baseUrl}}"], "path": ["v2","content","metadata"] },
            "description": "GET /v1/content/metadata\n\nReturns static moods, genres, and languages arrays."
          }
        },
        {
          "name": "Search Content",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/content/search?q=midnight",
              "host": ["{{baseUrl}}"],
              "path": ["v2","content","search"],
              "query": [
                { "key": "q",     "value": "midnight", "description": "Required — searches title, director, genre" },
                { "key": "type",  "value": "vertical-series", "disabled": true },
                { "key": "limit", "value": "20",              "disabled": true }
              ]
            },
            "description": "GET /v1/content/search?q=...\n\nFull-text search across title, director, and genre."
          }
        },
        {
          "name": "Get Content by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/v1/content/{{contentId}}", "host": ["{{baseUrl}}"], "path": ["v2","content","{{contentId}}"] },
            "description": "GET /v1/content/:id\n\nReturns full content detail including episodeList (for vertical-series)."
          }
        }
      ]
    },
    {
      "name": "Rentals",
      "description": "Rental & payment endpoints — Bearer token required.",
      "item": [
        {
          "name": "Initiate Rental",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/v1/rentals/initiate", "host": ["{{baseUrl}}"], "path": ["v2","rentals","initiate"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contentId\": \"{{contentId}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "POST /v1/rentals/initiate\n\nCreates a Razorpay order and returns gatewayOrderId + gatewayKey for the client SDK."
          }
        },
        {
          "name": "Confirm Payment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/v1/rentals/confirm", "host": ["{{baseUrl}}"], "path": ["v2","rentals","confirm"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"{{orderId}}\",\n  \"gatewayPaymentId\": \"rzp_pay_DEV123456\",\n  \"gatewaySignature\": \"dev_signature\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "POST /v1/rentals/confirm\n\nVerifies the Razorpay HMAC signature and writes the rental record."
          }
        },
        {
          "name": "List My Rentals",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/rentals?active=true",
              "host": ["{{baseUrl}}"],
              "path": ["v2","rentals"],
              "query": [
                { "key": "active", "value": "true", "description": "true → only non-expired rentals" }
              ]
            },
            "description": "GET /v1/rentals\n\nReturns all rentals for the authenticated user."
          }
        },
        {
          "name": "Get Rental Status",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/v1/rentals/{{contentId}}", "host": ["{{baseUrl}}"], "path": ["v2","rentals","{{contentId}}"] },
            "description": "GET /v1/rentals/:contentId\n\nReturns { isRented, rental } for the given content."
          }
        }
      ]
    },
    {
      "name": "Playback",
      "description": "Streaming URLs and watch-progress endpoints — Bearer token + active rental required for stream endpoints.",
      "item": [
        {
          "name": "Get Stream URL — Short Film",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/v1/content/{{contentId}}/stream", "host": ["{{baseUrl}}"], "path": ["v2","content","{{contentId}}","stream"] },
            "description": "GET /v1/content/:id/stream\n\nReturns a signed streaming URL for a short-film. Requires an active rental."
          }
        },
        {
          "name": "Get Stream URL — Episode",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/v1/content/{{contentId}}/episodes/{{episodeId}}/stream", "host": ["{{baseUrl}}"], "path": ["v2","content","{{contentId}}","episodes","{{episodeId}}","stream"] },
            "description": "GET /v1/content/:id/episodes/:episodeId/stream\n\nReturns a signed streaming URL for a vertical-series episode. Requires an active rental."
          }
        },
        {
          "name": "Save Watch Progress — Short Film",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/v1/content/{{contentId}}/progress", "host": ["{{baseUrl}}"], "path": ["v2","content","{{contentId}}","progress"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentTime\": 645,\n  \"duration\": 1080,\n  \"completed\": false\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "POST /v1/content/:id/progress — Short Film\n\nSaves playback position. Returns progressPercent."
          }
        },
        {
          "name": "Save Watch Progress — Episode",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/v1/content/{{contentId}}/progress", "host": ["{{baseUrl}}"], "path": ["v2","content","{{contentId}}","progress"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"episodeId\": \"{{episodeId}}\",\n  \"episodeNumber\": 1,\n  \"currentTime\": 87,\n  \"duration\": 132,\n  \"completed\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "POST /v1/content/:id/progress — Vertical Series Episode\n\nSaves progress for a specific episode."
          }
        },
        {
          "name": "Get Watch Progress",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/v1/content/{{contentId}}/progress", "host": ["{{baseUrl}}"], "path": ["v2","content","{{contentId}}","progress"] },
            "description": "GET /v1/content/:id/progress\n\nReturns current watch progress for the authenticated user."
          }
        }
      ]
    },
    {
      "name": "Users",
      "description": "User profile endpoints — Bearer token required.",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/v1/users/me", "host": ["{{baseUrl}}"], "path": ["v2","users","me"] },
            "description": "GET /v1/users/me\n\nReturns authenticated user profile with aggregated stats."
          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/v1/users/me", "host": ["{{baseUrl}}"], "path": ["v2","users","me"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"displayName\": \"Adarsh C.\",\n  \"avatarUrl\": \"https://cdn.shortsy.app/avatars/new.jpg\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "PATCH /v1/users/me\n\nUpdates displayName and/or avatarUrl."
          }
        },
        {
          "name": "Delete My Account",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/v1/users/me", "host": ["{{baseUrl}}"], "path": ["v2","users","me"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"SecurePass123!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "DELETE /v1/users/me\n\nDeletes the user account."
          }
        }
      ]
    }
  ]
}
