# ─── Shortsy Mobile — Development Environment ────────────────────────────────
# Loaded by react-native-config at build time.
# DO NOT commit .env.staging or .env.production — add them to .gitignore.

# ── API ───────────────────────────────────────────────────────────────────────
API_BASE_URL=https://2tngsao13b.execute-api.ap-south-1.amazonaws.com/v1

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Set to true to use in-memory mock data instead of the live API
USE_MOCK_API=false
# Simulated latency (ms) when USE_MOCK_API=true
MOCK_DELAY_MS=300

# ── Auth — Google OAuth ───────────────────────────────────────────────────────
GOOGLE_IOS_CLIENT_ID=411501052320-ctaen736unlri4e0fhapjujnf56b92jv.apps.googleusercontent.com
GOOGLE_WEB_CLIENT_ID=411501052320-i88soetdamgrna06pdj00peqsbuaac85.apps.googleusercontent.com
GOOGLE_OAUTH_REDIRECT_URI=com.googleusercontent.apps.411501052320-ctaen736unlri4e0fhapjujnf56b92jv:/oauth2redirect

# ── Payment Gateway — Razorpay ────────────────────────────────────────────────
# Use rzp_test_* for dev/staging, rzp_live_* for production
RAZORPAY_KEY_ID=rzp_test_SLajOeA4k89FaD

# ── App Web URLs ──────────────────────────────────────────────────────────────
# Base URL used for deep links and share messages
APP_WEB_URL=https://shortsy-7c19f.web.app
APP_DOMAIN=shortsy.app

# ── Business Logic — Revenue Split (display only in app) ─────────────────────
CREATOR_REVENUE_SHARE=0.7
PLATFORM_FEE_SHARE=0.3

# ── Rental Access Windows ────────────────────────────────────────────────────
# Number of days a renter has viewing access after payment.
# These MUST match RENTAL_EXPIRY_* on the backend (RENTAL_EXPIRY_CONFIG.md).
RENTAL_EXPIRY_SHORT_FILM_DAYS=1
RENTAL_EXPIRY_VERTICAL_SERIES_DAYS=3

# ── Premium Subscription ──────────────────────────────────────────────────────
# Monthly plan price in INR shown to users and charged via Razorpay
PREMIUM_PRICE_INR=199

# ── Content Cache ─────────────────────────────────────────────────────────────
# Duration in milliseconds before cached content is considered stale
CONTENT_CACHE_TTL_MS=300000
